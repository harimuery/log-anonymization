{
  "annotations": {
    "list": []
  },
  "description": "Log Anonymization Service Monitoring Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Processing Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "rate(masking_processed_total[1m])",
          "legendFormat": "Processed/s",
          "refId": "A"
        },
        {
          "expr": "rate(masking_hits_total[1m])",
          "legendFormat": "Hits/s ({{labels.dataType}})",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Processing Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(masking_latency_seconds_bucket[5m]))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, rate(masking_latency_seconds_bucket[5m]))",
          "legendFormat": "P99",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.999, rate(masking_latency_seconds_bucket[5m]))",
          "legendFormat": "P999",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "max": 1,
          "min": 0
        }
      },
      "targets": [
        {
          "expr": "rate(masking_errors_total[5m]) / rate(masking_processed_total[5m])",
          "legendFormat": "Error Rate",
          "refId": "A"
        },
        {
          "expr": "rate(masking_degraded_total[5m]) / rate(masking_processed_total[5m])",
          "legendFormat": "Degraded Rate",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Circuit Breaker State",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED", "color": "green" }, "1": { "text": "OPEN", "color": "red" }, "2": { "text": "HALF_OPEN", "color": "yellow" } } }
          ]
        }
      },
      "targets": [
        {
          "expr": "resilience4j_circuitbreaker_state{name=\"maskingEngine\"}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Hits by Data Type",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "fieldConfig": { "defaults": {} },
      "targets": [
        {
          "expr": "sum by(dataType) (rate(masking_hits_total[5m]))",
          "legendFormat": "{{dataType}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Audit Queue Size",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        }
      },
      "targets": [
        {
          "expr": "masking_audit_disruptor_queue_size",
          "legendFormat": "Queue Size",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Cache Performance",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "rate(masking_cache_hits_total[1m])",
          "legendFormat": "Cache Hits/s",
          "refId": "A"
        },
        {
          "expr": "rate(masking_cache_misses_total[1m])",
          "legendFormat": "Cache Misses/s",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Bloom Filter Effectiveness",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "red", "value": 0.95 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "rate(masking_bloom_filter_false_positives_total[10m]) / rate(masking_bloom_filter_queries_total[10m])",
          "refId": "A"
        }
      ]
    },
    {
      "title": "JVM Heap Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        }
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\"}",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_max_bytes{area=\"heap\"}",
          "legendFormat": "Max",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Rule Reload Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OK", "color": "green" } } }
          ]
        }
      },
      "targets": [
        {
          "expr": "increase(masking_rule_reload_errors_total[1h])",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["log-anonymization", "masking"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": true, "text": "Prometheus", "value": "Prometheus" }
      },
      {
        "name": "instance",
        "type": "query",
        "query": "label_values(masking_processed_total, instance)",
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Log Anonymization Dashboard",
  "uid": "log-anonymization",
  "version": 1
}